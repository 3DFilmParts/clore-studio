  upd(patch) {
    const active = this.state.active;
    const next = Object.assign({}, this.state.settings, { [active]: Object.assign(this.cur(), patch) });
    this.setState({ settings: next }, () => {
      this.persist();
      if (this.state.mode === 'anim') this.ensureLayers();
    });
