    this.setState({ presets: this.state.presets.concat([p]), presetName: '' }, () => this.persist());
  }

  mergePresets(incoming) {
    if (!Array.isArray(incoming)) return;
    const have = {};
    this.state.presets.forEach(p => { have[p.id] = 1; });
    const add = incoming.filter(p => p && p.id && p.file && !have[p.id]);
    if (add.length) this.setState({ presets: this.state.presets.concat(add) }, () => this.persist());
  }

  async loadPresetFile() {
    try {
      const r = await fetch('clore-templates/presets.json');
      if (r.ok) this.mergePresets(await r.json());
    } catch (e) { /* no preset file */ }
  }

  exportPresets() {
    const blob = new Blob([JSON.stringify(this.state.presets, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    this.download(url, 'presets.json');
    setTimeout(() => URL.revokeObjectURL(url), 5000);
  }

  importPresets(e) {
    const file = e.target && e.target.files && e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => {
      try { this.mergePresets(JSON.parse(reader.result)); } catch (err) { /* invalid file */ }
    };
    reader.readAsText(file);
  }

  applyPreset(p) {
    this.setState({
      active: p.file,
      anim: Object.assign({}, this.state.anim, p.anim || {})
    }, () => {
      this.upd(Object.assign({ format: p.format }, p.design || {}));
      this.loadImagesFor(this.cur().product);
    });
  }

  canvasRef = React.createRef();

  slug(t) {
    return String(t).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'design';
  }

  download(dataUrl, name) {
    const a = document.createElement('a');
    a.href = dataUrl;
    a.download = name;
    document.body.appendChild(a);
    a.click();
    a.remove();
  }

  async capture(file, settings, format, type) {
    const fm = this.FORMATS.find(f => f.f === format);
    const srcdoc = this.buildSrcdoc(file, settings, format);
    const iframe = document.createElement('iframe');
    iframe.style.cssText = 'position:fixed;left:-100000px;top:0;width:' + fm.w + 'px;height:' + fm.h + 'px;border:0';
    document.body.appendChild(iframe);
    try {
      await new Promise((res) => { iframe.onload = res; iframe.srcdoc = srcdoc; });
      const doc = iframe.contentDocument;
      try { await doc.fonts.ready; } catch (e) { /* ignore */ }
      const imgs = Array.prototype.slice.call(doc.images);
      await Promise.all(imgs.map(im => im.complete ? null : new Promise(r => { im.onload = r; im.onerror = r; })));
      await new Promise(r => setTimeout(r, 350));
      const card = doc.querySelector('.card');
      const lib = window.htmlToImage;
      if (!lib) throw new Error('export library not loaded, check network');
      const opts = { width: fm.w, height: fm.h, pixelRatio: (type === 'png' && this.state.hq) ? 2 : 1, cacheBust: true };
      if (type === 'png') return await lib.toPng(card, opts);
      if (type === 'jpeg') return await lib.toJpeg(card, Object.assign({}, opts, { quality: 0.92, backgroundColor: '#ffffff' }));
      return await lib.toSvg(card, opts);
    } finally {
      iframe.remove();
    }
  }

  async exportItems(items, type) {
    if (this.state.exporting || !items.length || !this.state.raw) return;
    const ext = type === 'jpeg' ? 'jpg' : type;
    for (let i = 0; i < items.length; i++) {
      this.setState({ exporting: 'Exporting ' + (i + 1) + ' of ' + items.length + '...' });
      try {
        const it = items[i];
        const dataUrl = await this.capture(it.file, it.settings, it.format, type);
        const name = this.slug(it.settings.title) + '_' + it.file.replace('.html', '') + '_' + it.format + '.' + ext;
        this.download(dataUrl, name);
        await new Promise(r => setTimeout(r, 600));
      } catch (e) {
        this.setState({ exporting: 'Export failed: ' + (e && e.message ? e.message : e) });
        await new Promise(r => setTimeout(r, 2000));
      }
    }
    this.setState({ exporting: '' });
  }

  /* ---------- Animation engine ---------- */

  RECIPES = {
    'T02-editorial.html': { imgBox: '.photo-card', hide: ['.photo-card img'], scrim: null,
      anim: [['.top', 'Logo + eyebrow'], ['.banner-head', 'Logo + eyebrow'], ['.circle-badge', 'Badge'], ['h1', 'Headline'], ['.meta', 'Price'], ['.footer', 'CTA footer']] },
    'T05A-editorial-light.html': { imgBox: '.card', hide: ['.hero'], scrim: '.scrim',
      anim: [['.logo', 'Logo'], ['.circle-badge', 'Badge'], ['.eyebrow', 'Eyebrow'], ['h1', 'Headline'], ['.rule', 'Accent rule'], ['.meta', 'Price'], ['.cta-row', 'CTA row']] },
    'T05B-editorial-dark.html': { imgBox: '.card', hide: ['.hero'], scrim: '.scrim',
      anim: [['.logo', 'Logo'], ['.circle-badge', 'Badge'], ['.eyebrow', 'Eyebrow'], ['h1', 'Headline'], ['.rule', 'Accent rule'], ['.meta', 'Price'], ['.cta-row', 'CTA row']] },
    'T10-dualsplit.html': { imgBox: '.half-1', imgBox2: '.half-2', hide: ['.img1', '.img2'], scrim: null,
      anim: [['.logo', 'Logo'], ['.pill', 'Badge'], ['.eyebrow', 'Eyebrow'], ['h1', 'Headline'], ['.meta', 'Price'], ['.cta-row', 'CTA row']] },
    'T11-herodetail.html': { imgBox: '.card', hide: ['.hero'], scrim: '.scrim',
      anim: [['.top', 'Logo'], ['.inset', 'Detail inset'], ['.eyebrow', 'Eyebrow'], ['h1', 'Headline'], ['.rule', 'Accent rule'], ['.meta', 'Price'], ['.cta-row', 'CTA row']] },
    'T12-campaign.html': { imgBox: null, hide: [], scrim: null,
      anim: [['.middle .logo', 'Logo'], ['.middle .eyebrow', 'Kicker'], ['.middle h1', 'Headline'], ['.code-badge', 'Code badge'], ['.footer', 'Footer']] },
    'T13-cameratape.html': { imgBox: '.photo-card', hide: ['.photo-card img'], scrim: null,
      anim: [['.top', 'Logo + badge'], ['.photo-card .tape-tl', 'Tape label A'], ['.photo-card .tape-br', 'Tape label B'], ['.eyebrow', 'Eyebrow'], ['h1', 'Headline'], ['.rule', 'Accent rule'], ['.meta', 'Price'], ['.cta-row', 'CTA row']] }
  };

  layerKey(sel) { return this.state.active + '|' + sel; }

  layerCfg(sel) { return (this.state.anim.layerCfg || {})[this.layerKey(sel)] || {}; }

  setLayerCfg(sel, patch) {
    const all = Object.assign({}, this.state.anim.layerCfg || {});
    all[this.layerKey(sel)] = Object.assign({}, all[this.layerKey(sel)] || {}, patch);
    this.setAnim({ layerCfg: all });
  }

  EASINGS = {
    linear: t => t,
    smooth: t => 1 - Math.pow(1 - t, 3),
    snappy: t => t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2,
    overshoot: t => { const c = 1.70158; return 1 + (c + 1) * Math.pow(t - 1, 3) + c * Math.pow(t - 1, 2); }
  };

  loadImg(url) {
    return new Promise((res) => {
      const im = new Image();
      im.crossOrigin = 'anonymous';
      im.onload = () => res(im);
      im.onerror = () => res(null);
      im.src = url;
    });
  }

  cyclePool(s) {
    const seen = {};
    const pool = [];
    const push = (u) => { if (u && !seen[u]) { seen[u] = 1; pool.push(u); } };
    push(s.custom1);
    (this.state.productImages[s.product.handle] || s.product.images || []).forEach(push);
    push(s.custom2);
    return pool.slice(0, Math.max(1, this.state.anim.imageCount));
  }

  animKey() {
    const s = this.cur();
    return JSON.stringify([this.state.active, s.format, s.title, s.eyebrow, s.price, s.badge,
      s.priceOn, s.badgeOn, s.img1, s.img2, !!s.custom1, !!s.custom2,
      s.scale1, s.scale2, s.posX1, s.posY1, s.posX2, s.posY2,
      this.state.anim.imageCount, this.state.raw ? 1 : 0]);
  }

  async ensureLayers() {
    if (!this.state.raw || this.state.mode !== 'anim') return;
    const key = this.animKey();
    if (this._builtKey === key && this.state.animLayers) return;
    this._wantKey = key;
    if (this._building) return;
    this._building = true;
    try {
      while (this._wantKey !== this._builtKey) {
        const k = this._wantKey;
        await this.buildLayers();
        this._builtKey = k;
      }
    } finally {
      this._building = false;
    }
  }

  async buildLayers(sOverride) {
    this.setState({ animStatus: 'Preparing layers, a few seconds...', animPlaying: false, animLayers: null });
    if (this._raf) cancelAnimationFrame(this._raf);
    const s = sOverride || this.cur();
    const active = this.state.active;
    const recipe = this.RECIPES[active];
    const fm = this.FORMATS.find(f => f.f === s.format);
    const iframe = document.createElement('iframe');
    iframe.style.cssText = 'position:fixed;left:-100000px;top:0;width:' + fm.w + 'px;height:' + fm.h + 'px;border:0';
    document.body.appendChild(iframe);
    try {
      const srcdoc = this.buildSrcdoc(active, s, s.format);
      await new Promise((res) => { iframe.onload = res; iframe.srcdoc = srcdoc; });
      const doc = iframe.contentDocument;
      const clampInfo = Array.prototype.map.call(doc.querySelectorAll('h1'), h => {
        const cs = getComputedStyle(h);
        return { h, clamp: parseInt(cs.webkitLineClamp, 10) || 0, lh: parseFloat(cs.lineHeight) || 0 };
      });
      const fixer = doc.createElement('style');
      fixer.textContent = 'h1 { display: block !important; -webkit-line-clamp: none !important; overflow: hidden !important; }';
      doc.head.appendChild(fixer);
      clampInfo.forEach(ci => { if (ci.clamp && ci.lh) ci.h.style.maxHeight = Math.ceil(ci.clamp * ci.lh + 2) + 'px'; });
      try { await doc.fonts.ready; } catch (e) { /* ignore */ }
      const imgsEls = Array.prototype.slice.call(doc.images);
      await Promise.all(imgsEls.map(im => im.complete ? null : new Promise(r => { im.onload = r; im.onerror = r; })));
      await new Promise(r => setTimeout(r, 300));
      const lib = window.htmlToImage;
      if (!lib) throw new Error('capture library not loaded');
      const card = doc.querySelector('.card');
      const cardR = card.getBoundingClientRect();
      const rel = (el) => {
        const r = el.getBoundingClientRect();
        return { x: r.left - cardR.left, y: r.top - cardR.top, w: r.width, h: r.height };
      };
      const visible = (el) => el && el.getBoundingClientRect().width > 1 && el.getBoundingClientRect().height > 1 && getComputedStyle(el).display !== 'none' && getComputedStyle(el).visibility !== 'hidden';
      const opts = { pixelRatio: 1, cacheBust: false };

      const texts = [];
      const animEls = [];
      for (const entry of recipe.anim) {
        const sel = entry[0], name = entry[1];
        const el = Array.prototype.find.call(doc.querySelectorAll(sel), e => visible(e));
        if (el && !animEls.some(a => a.el === el || a.el.contains(el) || el.contains(a.el))) {
          animEls.push({ sel, name, el, rect: rel(el) });
        }
      }
      const cardCap = async () => this.loadImg(await lib.toPng(card, Object.assign({}, opts, { width: fm.w, height: fm.h })));
      for (const a of animEls) {
        try {
          card.style.visibility = 'hidden';
          a.el.style.visibility = 'visible';
          const im = await cardCap();
          if (im) texts.push({ img: im, rect: a.rect, sel: a.sel, name: a.name });
        } catch (e) { /* skip failed layer */ }
        card.style.visibility = '';
        a.el.style.visibility = '';
      }
      let scrim = null;
      const scrimEl = recipe.scrim ? doc.querySelector(recipe.scrim) : null;
      if (visible(scrimEl)) {
        try {
          card.style.visibility = 'hidden';
          scrimEl.style.visibility = 'visible';
          scrim = await cardCap();
        } catch (e) { scrim = null; }
        card.style.visibility = '';
        scrimEl.style.visibility = '';
      }
      const boxOf = (sel) => {
        const el = sel ? doc.querySelector(sel) : null;
        if (!visible(el)) return null;
        const r = rel(el);
        r.r = parseFloat(getComputedStyle(el).borderRadius) || 0;
        return r;
      };
      const imgRect = boxOf(recipe.imgBox);
      const imgRect2 = boxOf(recipe.imgBox2);

      recipe.hide.forEach(sel => doc.querySelectorAll(sel).forEach(el => { el.style.visibility = 'hidden'; }));
      if (scrimEl) scrimEl.style.visibility = 'hidden';
      animEls.forEach(a => { a.el.style.visibility = 'hidden'; });
      const bgUrl = await lib.toPng(card, Object.assign({}, opts, { width: fm.w, height: fm.h }));
      const bg = await this.loadImg(bgUrl);

      let images = [];
      if (imgRect) {
        const pool = this.cyclePool(s);
        images = (await Promise.all(pool.map(u => this.loadImg(u)))).filter(Boolean);
      }
      const layers = { w: fm.w, h: fm.h, bg, scrim, texts, imgRect, imgRect2, images, s: { scale1: s.scale1, posX1: s.posX1, posY1: s.posY1, scale2: s.scale2, posX2: s.posX2, posY2: s.posY2 } };
      this.setState({ animLayers: layers, animStatus: '', animT: 0 }, () => {
        const c = this.canvasRef.current || this._offCanvas;
        if (c) { c.width = fm.w; c.height = fm.h; }
        this._t = 0;
        this.drawFrame(0);
        this.setState({ animPlaying: true }, () => this.startPlay());
      });
    } catch (e) {
      this.setState({ animStatus: 'Layer build failed: ' + (e && e.message ? e.message : e) });
    } finally {
      iframe.remove();
    }
  }

  animTotal() {
    const c = this.state.anim;
    const L = this.state.animLayers;
    const shown = L ? L.texts.filter(tl => this.layerCfg(tl.sel).visible !== false) : [];
    const nText = L ? shown.length : 2;
    const maxDelay = shown.reduce((m, tl) => Math.max(m, this.layerCfg(tl.sel).delay || 0), 0) * 1000;
    const n = L && L.images ? Math.max(1, Math.min(L.images.length, c.imageCount)) : 1;
    const entrance = 700;
    const imgEnd = L && L.imgRect ? entrance + n * c.hold * 1000 + (n - 1) * c.transDuration * 1000 : 0;
    const textEnd = (c.textDelay + c.textDuration) * 1000 + c.textStagger * 1000 * Math.max(0, nText - 1) + maxDelay;
    return Math.max(imgEnd, textEnd) + 400;
  }

  drawCover(ctx, img, rect, scale, posX, posY, zoom, panX, panY, alpha, dxAll) {
    if (!img) return;
    ctx.save();
    ctx.globalAlpha = alpha;
    ctx.beginPath();
    const r = Math.min(rect.r || 0, rect.w / 2, rect.h / 2);
    if (ctx.roundRect) ctx.roundRect(rect.x, rect.y, rect.w, rect.h, r);
    else ctx.rect(rect.x, rect.y, rect.w, rect.h);
    ctx.clip();
    const base = Math.max(rect.w / img.width, rect.h / img.height) * scale * zoom;
    const dw = img.width * base, dh = img.height * base;
    const dx = rect.x + (rect.w - dw) * (posX / 100) + (panX || 0) + (dxAll || 0);
    const dy = rect.y + (rect.h - dh) * (posY / 100) + (panY || 0);
    ctx.drawImage(img, dx, dy, dw, dh);
    ctx.restore();
  }

  imageStateAt(t, n) {
    const c = this.state.anim;
    const entrance = 700;
    const hold = c.hold * 1000, trans = c.transDuration * 1000;
    if (n <= 1) return { iA: 0, iB: 0, mix: 0, prog: Math.min(1, t / 8000) };
    const seg = hold + trans;
    const tc = Math.max(0, t - entrance);
    const k = Math.floor(tc / seg);
    const within = tc - k * seg;
    const iA = k % n;
    if (within < hold) return { iA, iB: (iA + 1) % n, mix: 0, prog: within / hold };
    return { iA, iB: (iA + 1) % n, mix: (within - hold) / trans, prog: 1 };
  }

  drawFrame(t) {
    const L = this.state.animLayers;
    const canvas = this.canvasRef.current || this._offCanvas;
    if (!L || !canvas) return;
    const c = this.state.anim;
    const ease = this.EASINGS[c.easing] || this.EASINGS.smooth;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, L.w, L.h);
    if (L.bg) ctx.drawImage(L.bg, 0, 0, L.w, L.h);

    if (L.imgRect && L.images.length) {
      const n = Math.max(1, Math.min(L.images.length, c.imageCount));
      const entrance = 700;
      const ep = Math.min(1, t / entrance);
      const ee = ease(Math.max(0, ep));
      let eAlpha = 1, eZoom = 1, eDx = 0;
      if (c.imageEntrance === 'fade') eAlpha = ee;
      if (c.imageEntrance === 'scale') { eAlpha = ee; eZoom = 1.18 - 0.18 * ee; }
      if (c.imageEntrance === 'slide') { eAlpha = ee; eDx = (1 - ee) * -L.imgRect.w * 0.25; }
      const st = this.imageStateAt(t, n);
      const kb = (prog, idx) => {
        if (!c.kenburns) return { z: 1, px: 0, py: 0 };
        const dir = idx % 2 === 0 ? 1 : -1;
        return { z: 1 + c.kbAmount * prog, px: dir * prog * L.imgRect.w * 0.02, py: -prog * L.imgRect.h * 0.015 };
      };
      const drawIn = (rect, shift, sc, px, py) => {
        const iA = (st.iA + shift) % n, iB = (st.iB + shift) % n;
        const ka = kb(st.prog, iA);
        if (st.mix <= 0 || c.transition === 'cut') {
          const idx = (st.mix > 0.5 && c.transition === 'cut') ? iB : iA;
          this.drawCover(ctx, L.images[idx], rect, sc, px, py, eZoom * ka.z, ka.px, ka.py, eAlpha, eDx);
        } else {
          const m = ease(st.mix);
          const kbB = kb(0, iB);
          if (c.transition === 'slide') {
            this.drawCover(ctx, L.images[iA], rect, sc, px, py, ka.z, ka.px, ka.py, 1, -m * rect.w);
            this.drawCover(ctx, L.images[iB], rect, sc, px, py, kbB.z, kbB.px, kbB.py, 1, (1 - m) * rect.w);
          } else if (c.transition === 'zoom') {
            this.drawCover(ctx, L.images[iA], rect, sc, px, py, ka.z, ka.px, ka.py, 1 - m, 0);
            this.drawCover(ctx, L.images[iB], rect, sc, px, py, (1.15 - 0.15 * m) * kbB.z, kbB.px, kbB.py, m, 0);
          } else {
            this.drawCover(ctx, L.images[iA], rect, sc, px, py, ka.z, ka.px, ka.py, 1, 0);
            this.drawCover(ctx, L.images[iB], rect, sc, px, py, kbB.z, kbB.px, kbB.py, m, 0);
          }
        }
      };
      drawIn(L.imgRect, 0, L.s.scale1, L.s.posX1, L.s.posY1);
      if (L.imgRect2) drawIn(L.imgRect2, 1, L.s.scale2, L.s.posX2, L.s.posY2);
    }

    if (L.scrim) ctx.drawImage(L.scrim, 0, 0, L.w, L.h);

    const shown = L.texts.filter(tl => this.layerCfg(tl.sel).visible !== false);
    shown.forEach((tl, i) => {
      const cfg = this.layerCfg(tl.sel);
      const eff = (cfg.effect && cfg.effect !== 'global') ? cfg.effect : c.textEffect;
      const start = c.textDelay * 1000 + i * c.textStagger * 1000 + (cfg.delay || 0) * 1000;
      let p = eff === 'none' ? 1 : (t - start) / (c.textDuration * 1000);
      p = Math.max(0, Math.min(1, p));
      const e = ease(p);
      if (e <= 0) return;
      ctx.save();
      ctx.globalAlpha = Math.max(0, Math.min(1, e));
      let dx = 0, dy = 0, sc = 1;
      if (eff === 'rise') dy = (1 - e) * 70;
      if (eff === 'slide') dx = (1 - e) * -90;
      if (eff === 'scale') sc = 0.88 + 0.12 * e;
      const r = tl.rect;
      if (sc !== 1) {
        ctx.translate(r.x + r.w / 2, r.y + r.h / 2);
        ctx.scale(sc, sc);
        ctx.translate(-(r.x + r.w / 2), -(r.y + r.h / 2));
      }
      ctx.drawImage(tl.img, dx, dy, L.w, L.h);
      ctx.restore();
    });
  }

  startPlay() {
    if (this._raf) cancelAnimationFrame(this._raf);
    this._playStart = performance.now() - (this._t || 0);
    const step = () => {
      if (!this.state.animPlaying || this.state.mode !== 'anim') return;
      let t = performance.now() - this._playStart;
      const total = this.animTotal();
      if (t >= total) {
        if (this.state.anim.loop) { this._playStart = performance.now(); t = 0; }
        else { t = total; this._t = t; this.drawFrame(t); this.setState({ animPlaying: false, animT: Math.round(t) }); return; }
      }
      this._t = t;
      this.drawFrame(t);
      if (performance.now() - (this._lastTick || 0) > 200) {
        this._lastTick = performance.now();
        this.setState({ animT: Math.round(t) });
      }
      this._raf = requestAnimationFrame(step);
    };
    this._raf = requestAnimationFrame(step);
  }

  async exportVideo(sOverride) {
    const L = this.state.animLayers;
    const canvas = this.canvasRef.current || this._offCanvas;
    if (!L || !canvas || this._recording) return;
    if (!window.MediaRecorder) { this.setState({ animStatus: 'This browser cannot record video' }); return; }
    const mimes = ['video/mp4;codecs=avc1.42E01E', 'video/mp4', 'video/webm;codecs=vp9', 'video/webm'];
    const mime = mimes.find(m => MediaRecorder.isTypeSupported(m));
    if (!mime) { this.setState({ animStatus: 'No supported video format' }); return; }
    this._recording = true;
    if (this._raf) cancelAnimationFrame(this._raf);
    this.setState({ animPlaying: false, animStatus: 'Recording ' + (mime.indexOf('mp4') >= 0 ? 'MP4' : 'WebM') + '...' });
    try {
      const stream = canvas.captureStream(30);
      const rec = new MediaRecorder(stream, { mimeType: mime, videoBitsPerSecond: 14000000 });
      const chunks = [];
      rec.ondataavailable = e => { if (e.data && e.data.size) chunks.push(e.data); };
      const stopped = new Promise(res => { rec.onstop = res; });
      const total = this.animTotal();
      rec.start(250);
      const t0 = performance.now();
      await new Promise(res => {
        const step = () => {
          const t = performance.now() - t0;
          this.drawFrame(Math.min(t, total));
          if (t >= total + 150 || this._cancelExport) res();
          else requestAnimationFrame(step);
        };
        step();
      });
      rec.stop();
      await stopped;
      if (this._cancelExport) {
        this.setState({ animStatus: 'Export stopped' });
        this._recording = false;
        return;
      }
      const blob = new Blob(chunks, { type: mime });
      const ext = mime.indexOf('mp4') >= 0 ? 'mp4' : 'webm';
      const s = sOverride || this.cur();
      const url = URL.createObjectURL(blob);
      this.download(url, this.slug(s.title) + '_' + this.state.active.replace('.html', '') + '_' + s.format + '_anim.' + ext);
      setTimeout(() => URL.revokeObjectURL(url), 5000);
      this.setState({ animStatus: ext === 'webm' ? 'Saved as WebM (this browser cannot encode MP4)' : '' });
    } catch (e) {
      this.setState({ animStatus: 'Recording failed: ' + (e && e.message ? e.message : e) });
    } finally {
      this._recording = false;
    }
  }

  setAnim(patch) {
    this.setState({ anim: Object.assign({}, this.state.anim, patch) }, () => {
      this.persist();
      if (patch.imageCount !== undefined) { this._builtKey = ''; this.ensureLayers(); }
      else this.drawFrame(this._t || 0);
    });
  }

