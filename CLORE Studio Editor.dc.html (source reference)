  parseCatalogMd(md) {
    const out = [];
    const blocks = md.split('\n### ').slice(1);
    for (const b of blocks) {
      const label = b.split('\n')[0].trim();
      const url = (b.match(/- URL: (\S+)/) || [])[1] || '';
      const img = (b.match(/- Image: (\S+)/) || [])[1] || '';
      const priceM = b.match(/- Price: AUD \$([\d.]+)/);
      const tagsM = b.match(/- Tags: (.+)/);
      if (!img || url.indexOf('/products/') < 0) continue;
      out.push({
        handle: url.split('/products/')[1].trim(),
        label,
        title: label.toUpperCase(),
        price: priceM ? '$' + Number(priceM[1]).toFixed(2) : '',
        eyebrow: tagsM ? tagsM[1].split(',')[0].trim().toLowerCase() : 'made in melbourne',
        badge: b.indexOf('Top Seller') >= 0 || b.indexOf('top-seller') >= 0 ? 'BEST SELLER' : '',
        images: [img]
      });
    }
    return out;
  }

