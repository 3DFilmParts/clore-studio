              img1: p.images[0], img2: p.images[1] || p.images[0],
              custom1: null, custom2: null,
              scale1: 1, scale2: 1, posX1: 50, posY1: 50, posX2: 50, posY2: 50
            });
            this.loadImagesFor(p).then(urls => {
              if (urls && urls.length && this.cur().product.handle === p.handle) {
                this.upd({ img1: urls[0], img2: urls[1] || urls[0] });
              }
            });
          }
        }));
      })(),
      productCount: (() => {
        const catalog = this.state.catalog;
        if (!catalog) return 'Loading catalogue...';
        const q = this.state.productQuery.trim().toLowerCase();
        const n = q ? catalog.filter(p => p.label.toLowerCase().indexOf(q) >= 0).length : catalog.length;
        return n + ' product' + (n === 1 ? '' : 's') + '.';
      })(),
      title: s.title, eyebrow: s.eyebrow, price: s.price, badge: s.badge,
      onTitle: (e) => this.upd({ title: e.target.value }),
      titleScale: s.titleScale ?? 1,
      titleScaleLabel: (s.titleScale ?? 1).toFixed(2) + 'x',
      onTitleScale: (e) => this.upd({ titleScale: Number(e.target.value) }),
      onEyebrow: (e) => this.upd({ eyebrow: e.target.value }),
      onPrice: (e) => this.upd({ price: e.target.value }),
      onBadge: (e) => this.upd({ badge: e.target.value }),
      priceToggleLabel: s.priceOn ? 'ON' : 'OFF',
      badgeToggleLabel: s.badgeOn ? 'ON' : 'OFF',
      priceToggleStyle: toggle(s.priceOn),
      badgeToggleStyle: toggle(s.badgeOn),
      onTogglePrice: () => this.upd({ priceOn: !s.priceOn }),
      onToggleBadge: () => this.upd({ badgeOn: !s.badgeOn }),
      hasImage1: def.hasImg,
      hasImage2: !!def.img2,
      image2Label: def.img2 || '',
      thumbs1: imgs.map(src => thumb(src, s.custom1 ? '' : s.img1, 'img1')),
      thumbs2: imgs.map(src => thumb(src, s.custom2 ? '' : s.img2, 'img2')),
      onPrev1: () => step1(-1),
      onNext1: () => step1(1),
      onDragOver: (e) => e.preventDefault(),
      onDrop1: this.readDrop('custom1'),
      onDrop2: this.readDrop('custom2'),
      onFile1: this.readDrop('custom1'),
      onFile2: this.readDrop('custom2'),
      hasCustom1: !!s.custom1,
      hasCustom2: !!s.custom2,
      onClearCustom1: () => this.upd({ custom1: null }),
      onClearCustom2: () => this.upd({ custom2: null }),
      scale1: s.scale1, scale2: s.scale2,
      scale1Label: s.scale1.toFixed(2) + 'x',
      scale2Label: s.scale2.toFixed(2) + 'x',
      onScale1: (e) => this.upd({ scale1: Number(e.target.value) }),
      onScale2: (e) => this.upd({ scale2: Number(e.target.value) }),
      posX1: s.posX1, posY1: s.posY1, posX2: s.posX2, posY2: s.posY2,
      posX1Label: s.posX1 + '%', posY1Label: s.posY1 + '%',
      posX2Label: s.posX2 + '%', posY2Label: s.posY2 + '%',
      onPosX1: (e) => this.upd({ posX1: Number(e.target.value) }),
      onPosY1: (e) => this.upd({ posY1: Number(e.target.value) }),
      onPosX2: (e) => this.upd({ posX2: Number(e.target.value) }),
      onPosY2: (e) => this.upd({ posY2: Number(e.target.value) }),
      onReset: () => {
        const next = Object.assign({}, this.state.settings);
        delete next[active];
        this.setState({ settings: next }, () => this.persist());
      },
      exportBtnStyle: {
        fontFamily: "'JetBrains Mono', monospace", fontWeight: 700, fontSize: 11,
        letterSpacing: '0.1em', textTransform: 'uppercase', padding: '9px 14px',
        border: '2px solid #141414', background: '#141414', color: '#fff', cursor: 'pointer'
      },
      queueBtnStyle: {
        fontFamily: "'JetBrains Mono', monospace", fontWeight: 700, fontSize: 11,
        letterSpacing: '0.1em', textTransform: 'uppercase', padding: '9px 14px',
        border: '2px solid #E8231F', background: '#E8231F', color: '#fff', cursor: 'pointer'
      },
      clearBtnStyle: {
        fontFamily: "'JetBrains Mono', monospace", fontWeight: 700, fontSize: 11,
        letterSpacing: '0.1em', textTransform: 'uppercase', padding: '9px 14px',
        border: '2px solid #D3CFC3', background: '#fff', color: '#54534F', cursor: 'pointer'
      },
      hqStyle: toggle(this.state.hq),
      hqLabel: this.state.hq ? 'HQ 2X ON' : 'HQ 2X OFF',
      onToggleHq: () => this.setState({ hq: !this.state.hq }),
      exporting: this.state.exporting,
      onExportPng: () => this.exportItems([{ file: active, settings: s, format: s.format }], 'png'),
      onExportJpeg: () => this.exportItems([{ file: active, settings: s, format: s.format }], 'jpeg'),
      onExportSvg: () => this.exportItems([{ file: active, settings: s, format: s.format }], 'svg'),
      onQueueAdd: () => {
        const item = {
          id: Date.now() + '-' + Math.random().toString(36).slice(2, 7),
          file: active, format: s.format, settings: s
        };
        this.setState({ queue: this.state.queue.concat([item]) }, () => this.persist());
      },
      hasQueue: this.state.queue.length > 0,
      queueCount: this.state.queue.length + ' item' + (this.state.queue.length === 1 ? '' : 's'),
      queueItems: this.state.queue.map(q => ({
        label: q.file.split('-')[0] + ' · ' + q.format + ' · ' + this.slug(q.settings.title).slice(0, 28),
        onRemove: () => this.setState({ queue: this.state.queue.filter(x => x.id !== q.id) }, () => this.persist())
      })),
      onQueueClear: () => this.setState({ queue: [] }, () => this.persist()),
      onExportAllPng: () => this.exportItems(this.state.queue, 'png'),
      onExportAllJpeg: () => this.exportItems(this.state.queue, 'jpeg'),
      onExportAllSvg: () => this.exportItems(this.state.queue, 'svg'),
      presetName: this.state.presetName,
      onPresetName: (e) => this.setState({ presetName: e.target.value }),
      onSavePreset: () => this.savePreset(),
      onExportPresets: () => this.exportPresets(),
      onImportPresets: (e) => this.importPresets(e),
      presetRows: this.state.presets.map(p => ({
        name: p.name,
        applyStyle: Object.assign(btn(false), { flex: '1 1 auto', minWidth: 0, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }),
        onApply: () => this.applyPreset(p),
        onRemove: () => this.setState({ presets: this.state.presets.filter(x => x.id !== p.id) }, () => this.persist())
      })),
      logoColorOpts: [['auto', 'Auto'], ['ink', 'Black'], ['white', 'White']].map(o => ({
        label: o[1], style: toggle(o[0] === (s.logoColor || 'auto')), onPick: () => this.upd({ logoColor: o[0] })
      })),
      isTapeTpl: active === 'T13-cameratape.html',
      tapeBgOpts: [['frame-b', 'Tape 1 · dark'], ['frame-f', 'Tape 2 · paper'], ['frame-g', 'Tape 3 · red'], ['frame-h', 'Tape 4 · airy'], ['frame-i', 'Tape 5 · border']].map(o => ({
        label: o[1], style: toggle(o[0] === (s.tapeBg || 'frame-h')), onPick: () => this.upd({ tapeBg: o[0] })
      })),
      isDesign: this.state.mode === 'design',
      isAnim: this.state.mode === 'anim',
      isReel: this.state.mode === 'reel',
      isNotReel: this.state.mode !== 'reel',
      modeDesignStyle: toggle(this.state.mode === 'design'),
      modeAnimStyle: toggle(this.state.mode === 'anim'),
      modeReelStyle: toggle(this.state.mode === 'reel'),
      isBatch: this.state.mode === 'batch',
      modeBatchStyle: toggle(this.state.mode === 'batch'),
      onModeBatch: () => {
        if (this._raf) cancelAnimationFrame(this._raf);
        this.stopReel();
        this.setState({ mode: 'batch', animPlaying: false }, () => {
          if (!(this.state.batch || []).length) this.shuffleBatch();
        });
      },
      onShuffleBatch: () => this.shuffleBatch(),
      onExportBatchPng: () => this.exportBatch('png'),
      onExportBatchJpeg: () => this.exportBatch('jpeg'),
      onExportBatchVideos: () => this.exportBatchVideos(),
      onStopExport: () => this.stopExport(),
      isExporting: !!this.state.exporting || !!this._recording,
      batchRows: (this.state.mode === 'batch' && this.state.raw && !this.state.error ? (this.state.batch || []) : []).map(p => {
        const si = this.batchSettings(p);
        const bs = 0.155;
        return {
          label: p.label,
          srcdoc: this.buildSrcdoc(active, si, si.format),
          wrapStyle: {
            width: Math.round(fmt.w * bs), height: Math.round(fmt.h * bs),
            overflow: 'hidden', position: 'relative', flex: '0 0 auto', background: '#fff',
            boxShadow: '0 12px 28px rgba(20,20,20,.18)'
          },
          frameStyle: {
            width: fmt.w, height: fmt.h, border: 0, transform: 'scale(' + bs + ')',
            transformOrigin: 'top left', position: 'absolute', top: 0, left: 0, pointerEvents: 'none'
          }
        };
      }),
      onModeDesign: () => {
        if (this._raf) cancelAnimationFrame(this._raf);
        this.stopReel();
        this.setState({ mode: 'design', animPlaying: false });
      },
      onModeAnim: () => { this.stopReel(); this.setState({ mode: 'anim' }, () => this.ensureLayers()); },
      onModeReel: () => {
        if (this._raf) cancelAnimationFrame(this._raf);
        this.setState({ mode: 'reel', animPlaying: false }, () => {
          this.ensureReelAssets();
          setTimeout(() => this.drawReel(), 50);
        });
      },
      ...this.reelVals(toggle, btn),
      textEffectOpts: [['none', 'None'], ['fade', 'Fade'], ['rise', 'Rise'], ['slide', 'Slide'], ['scale', 'Scale']].map(o => ({
        label: o[1], style: toggle(o[0] === this.state.anim.textEffect), onPick: () => this.setAnim({ textEffect: o[0] })
      })),
      easingOpts: [['smooth', 'Smooth'], ['snappy', 'Snappy'], ['overshoot', 'Overshoot'], ['linear', 'Linear']].map(o => ({
        label: o[1], style: toggle(o[0] === this.state.anim.easing), onPick: () => this.setAnim({ easing: o[0] })
      })),
      imageEntranceOpts: [['none', 'None'], ['fade', 'Fade'], ['scale', 'Scale'], ['slide', 'Slide']].map(o => ({
        label: o[1], style: toggle(o[0] === this.state.anim.imageEntrance), onPick: () => this.setAnim({ imageEntrance: o[0] })
      })),
      transitionOpts: [['cut', 'Cut'], ['fade', 'Crossfade'], ['slide', 'Slide'], ['zoom', 'Zoom']].map(o => ({
        label: o[1], style: toggle(o[0] === this.state.anim.transition), onPick: () => this.setAnim({ transition: o[0] })
      })),
      textDur: this.state.anim.textDuration,
      textDurLabel: this.state.anim.textDuration.toFixed(2) + 's',
      onTextDur: (e) => this.setAnim({ textDuration: Number(e.target.value) }),
      textStagger: this.state.anim.textStagger,
      textStaggerLabel: this.state.anim.textStagger.toFixed(2) + 's',
      onTextStagger: (e) => this.setAnim({ textStagger: Number(e.target.value) }),
      textDelay: this.state.anim.textDelay,
      textDelayLabel: this.state.anim.textDelay.toFixed(2) + 's',
      onTextDelay: (e) => this.setAnim({ textDelay: Number(e.target.value) }),
      animHasImages: !!this.RECIPES[active].imgBox,
      imageCount: this.state.anim.imageCount,
      imageCountLabel: String(this.state.anim.imageCount),
      onImageCount: (e) => this.setAnim({ imageCount: Number(e.target.value) }),
      hold: this.state.anim.hold,
      holdLabel: this.state.anim.hold.toFixed(1) + 's',
      onHold: (e) => this.setAnim({ hold: Number(e.target.value) }),
      transDur: this.state.anim.transDuration,
      transDurLabel: this.state.anim.transDuration.toFixed(2) + 's',
      onTransDur: (e) => this.setAnim({ transDuration: Number(e.target.value) }),
      kbStyle: toggle(this.state.anim.kenburns),
      kbLabel: this.state.anim.kenburns ? 'ON' : 'OFF',
      onToggleKb: () => this.setAnim({ kenburns: !this.state.anim.kenburns }),
      kbAmount: this.state.anim.kbAmount,
      kbAmountLabel: '+' + Math.round(this.state.anim.kbAmount * 100) + '%',
      onKbAmount: (e) => this.setAnim({ kbAmount: Number(e.target.value) }),
      loopStyle: toggle(this.state.anim.loop),
      loopLabel: this.state.anim.loop ? 'LOOP ON' : 'LOOP OFF',
      onToggleLoop: () => this.setAnim({ loop: !this.state.anim.loop }),
      onRebuild: () => { this._builtKey = ''; this.ensureLayers(); },
      noLayers: !this.state.animLayers || !this.state.animLayers.texts.length,
      layerRows: (this.state.animLayers ? this.state.animLayers.texts : []).map(tl => {
        const cfg = this.layerCfg(tl.sel);
        const on = cfg.visible !== false;
        return {
          name: tl.name,
          toggleStyle: toggle(on),
          toggleLabel: on ? 'ON' : 'OFF',
          onToggle: () => this.setLayerCfg(tl.sel, { visible: !on }),
          effect: cfg.effect || 'global',
          onEffect: (e) => this.setLayerCfg(tl.sel, { effect: e.target.value }),
          delay: cfg.delay || 0,
          delayLabel: (cfg.delay || 0).toFixed(2) + 's',
          onDelay: (e) => this.setLayerCfg(tl.sel, { delay: Number(e.target.value) })
        };
      }),
      canvasRef: this.canvasRef,
      stageWrapStyle: (() => {
        const Ld = this.state.animLayers;
        const sw = Ld ? Ld.w : fmt.w, sh = Ld ? Ld.h : fmt.h;
        return wrap(sw, sh, Math.min(1100 / sw, 700 / sh, 0.62));
      })(),
      canvasStyle: { width: '100%', height: '100%', display: 'block' },
      animStatus: this.state.animStatus,
      animT: this.state.animT,
      animTotalMs: Math.round(this.animTotal()),
      animTimeLabel: (this.state.animT / 1000).toFixed(1) + 's / ' + (this.animTotal() / 1000).toFixed(1) + 's',
      onScrub: (e) => {
        const t = Number(e.target.value);
        this._t = t;
        this._playStart = performance.now() - t;
        this.setState({ animT: t });
        this.drawFrame(t);
      },
      playLabel: this.state.animPlaying ? 'Pause' : 'Play',
      onPlayPause: () => {
        if (this.state.animPlaying) {
          if (this._raf) cancelAnimationFrame(this._raf);
          this.setState({ animPlaying: false });
        } else {
          this.setState({ animPlaying: true }, () => this.startPlay());
        }
      },
      onRestart: () => {
        this._t = 0;
        this.setState({ animT: 0, animPlaying: true }, () => this.startPlay());
      },
      onExportVideo: () => { this._cancelExport = false; this.exportVideo(); },
      videoNote: 'Records in real time at 30 fps at full production resolution. Chrome and Edge save MP4; other browsers fall back to WebM. Layers rebuild automatically when the design changes; use Rebuild layers if something looks stale.',
      mainTitle: this.state.mode === 'reel' ? 'REEL MAKER' : def.name,
      mainLabel: this.state.mode === 'reel' ? ('story 1080x1920 · ' + (this._fps ? this._fps + ' fps (source)' : 'fps matches source')) : fmt.label,
      logoNote: this.state.mode === 'reel' ? this.reelSkinNote() : (def.logo === 'ink' ? 'ink logo (light ground)' : 'white logo (dark ground)'),
      main, minis
    };
  }
}
</script>
</body>
</html>
