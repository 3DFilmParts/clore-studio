  stopExport() {
    this._cancelExport = true;
    this.setState({ exporting: 'Stopping...' });
  }

  async exportBatchVideos() {
    if (this._recording || this.state.exporting) return;
    this._cancelExport = false;
    const items = this.state.batch || [];
    if (!this._offCanvas) this._offCanvas = document.createElement('canvas');
    for (let i = 0; i < items.length; i++) {
      if (this._cancelExport) break;
      const si = this.batchSettings(items[i]);
      this.setState({ exporting: 'Video ' + (i + 1) + ' / ' + items.length + ' — building layers...' });
      this.setState({ animLayers: null });
      await this.buildLayers(si);
      // wait for the layer state to land (buildLayers resolves before setState flushes)
      let tries = 0;
      while (!this.state.animLayers && tries < 40) {
        await new Promise(r => setTimeout(r, 100));
        tries++;
      }
      const L = this.state.animLayers;
      if (!L) {
        this.setState({ exporting: 'Layer build failed on item ' + (i + 1) });
        this._builtKey = '';
        return;
      }
      // size the (offscreen) canvas to full production dimensions BEFORE capture
      const bc = this.canvasRef.current || this._offCanvas;
      if (bc && (bc.width !== L.w || bc.height !== L.h)) { bc.width = L.w; bc.height = L.h; }
      this.drawFrame(0);
      this.setState({ exporting: 'Video ' + (i + 1) + ' / ' + items.length + ' — recording in real time...' });
      await this.exportVideo(si);
      await new Promise(r => setTimeout(r, 400));
    }
    this._builtKey = '';
    this._cancelExport = false;
    this.setState({ exporting: '', animLayers: null });
  }

  async exportBatch(type) {
    if (this._recording || this.state.exporting) return;
    this._cancelExport = false;
    const ext = type === 'jpeg' ? 'jpg' : type;
    const items = this.state.batch;
    for (let i = 0; i < items.length; i++) {
      if (this._cancelExport) break;
      this.setState({ exporting: 'Exporting ' + (i + 1) + ' / ' + items.length + '...' });
      try {
        const si = this.batchSettings(items[i]);
        const dataUrl = await this.capture(this.state.active, si, si.format, type);
        this.download(dataUrl, this.slug(si.title) + '_' + this.state.active.replace('.html', '') + '_' + si.format + '.' + ext);
        await new Promise(r => setTimeout(r, 600));
      } catch (e) {
        this.setState({ exporting: 'Failed on item ' + (i + 1) + ': ' + e });
        return;
      }
    }
    this._cancelExport = false;
    this.setState({ exporting: '' });
  }

  assetUrl(p) {
    const a = window.CLORE_ASSETS && window.CLORE_ASSETS[p];
    if (typeof a === 'string' && a.indexOf('data:') === 0) return a;
    return new URL(p, window.location.href).href;
  }

  measureFps(v) {
    this._fps = 0;
    const times = [];
    const cb = (now, meta) => {
      times.push(meta.mediaTime);
      if (times.length >= 14) {
        const ds = [];
        for (let i = 1; i < times.length; i++) {
          const d = times[i] - times[i - 1];
          if (d > 0.001) ds.push(d);
        }
        if (ds.length >= 5) {
          ds.sort((a, b) => a - b);
          const f = Math.round(1 / ds[Math.floor(ds.length / 2)]);
          if (f >= 10 && f <= 60) this._fps = f;
        }
        v.pause();
        v.muted = false;
        try { v.currentTime = 0.01; } catch (e) {}
        this.forceUpdate();
        return;
      }
      v.requestVideoFrameCallback(cb);
    };
    v.muted = true;
    v.play().then(() => v.requestVideoFrameCallback(cb)).catch(() => {
      v.muted = false;
      try { v.currentTime = 0.01; } catch (e) {}
    });
  }

  setReel(patch) {
    this.setState({ reel: Object.assign({}, this.state.reel, patch) }, () => {
      this.persist();
      this.syncCtaImg();
      this.drawReel();
    });
  }

  setCta(patch) {
    this.setReel({ cta: Object.assign({}, this.state.reel.cta || {}, patch) });
  }

  syncCtaImg() {
    const cta = this.state.reel.cta || {};
    if (cta.image && this._ctaImgSrc !== cta.image) {
      this._ctaImgSrc = cta.image;
      this.loadImg(cta.image).then(im => { this._ctaImg = im; this.drawReel(); });
    }
    if (!cta.image) { this._ctaImg = null; this._ctaImgSrc = null; }
  }

  wrapLines(ctx, text, maxW) {
    const words = String(text || '').split(/\s+/);
    const lines = [];
    let line = '';
    for (const wd of words) {
      const trial = line ? line + ' ' + wd : wd;
      if (ctx.measureText(trial).width > maxW && line) { lines.push(line); line = wd; }
      else line = trial;
    }
    if (line) lines.push(line);
    return lines;
  }

  drawCtaCard(ctx, ctaT, el, A) {
    const cta = this.state.reel.cta || {};
    const BG = { red: '#E8231F', ink: '#141414', white: '#FFFFFF', paper: '#F2EFE8' };
    const light = cta.bg === 'white' || cta.bg === 'paper';
    ctx.fillStyle = BG[cta.bg] || '#E8231F';
    ctx.fillRect(0, 0, 1080, 1920);
    const e = 1 - Math.pow(1 - Math.min(1, Math.max(0, ctaT / 0.5)), 3);
    const dy = (1 - e) * 46;
    ctx.save();
    ctx.globalAlpha = e;
    if (el.logo) {
      const lcc = this.state.reel.logoColor;
      const logo = lcc === 'ink' ? A.ink : lcc === 'white' ? A.white : (light ? A.ink : A.white);
      if (logo && logo.height) {
        const h = 58, w = logo.width * (h / logo.height);
        ctx.drawImage(logo, 540 - w / 2, 110 + dy, w, h);
      }
    }
    if (this._ctaImg && this._ctaImg.width) {
      const box = 1080 * ((Number(cta.imgSize) || 58) / 100);
      const cy = 1920 * ((Number(cta.imgY) || 62) / 100);
      const pad = 20;
      const FR = { white: '#FFFFFF', red: '#E8231F', ink: '#141414' };
      const rad = Number(cta.radius) || 0;
      ctx.fillStyle = FR[cta.frame] || '#FFFFFF';
      this.rrPath(ctx, 540 - box / 2 - pad, cy - box / 2 - pad + dy, box + pad * 2, box + pad * 2, rad);
      ctx.fill();
      ctx.save();
      this.rrPath(ctx, 540 - box / 2, cy - box / 2 + dy, box, box, Math.max(0, rad - 10));
      ctx.clip();
      ctx.fillStyle = '#FFFFFF';
      ctx.fillRect(540 - box / 2, cy - box / 2 + dy, box, box);
      const im = this._ctaImg;
      const sc = Math.min(box / im.width, box / im.height);
      ctx.drawImage(im, 540 - (im.width * sc) / 2, cy - (im.height * sc) / 2 + dy, im.width * sc, im.height * sc);
      ctx.restore();
    }
    const ty = 1920 * ((Number(cta.textY) || 28) / 100);
    const size = Number(cta.size) || 104;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.font = '900 ' + size + 'px Archivo, "Arial Black", sans-serif';
    try { ctx.letterSpacing = (-0.03 * size).toFixed(1) + 'px'; } catch (er) {}
    ctx.fillStyle = light ? '#141414' : '#FFFFFF';
    const lines = this.wrapLines(ctx, String(cta.headline || '').toUpperCase(), 904);
    const lh = size * 0.98;
    lines.forEach((ln, i) => ctx.fillText(ln, 540, ty + dy + i * lh));
    if (cta.sub) {
      ctx.font = '700 34px "JetBrains Mono", monospace';
      try { ctx.letterSpacing = '6px'; } catch (er) {}
      ctx.fillStyle = cta.bg === 'red' ? '#FFFFFF' : '#E8231F';
      ctx.fillText(String(cta.sub).toUpperCase(), 540, ty + dy + lines.length * lh + 16);
    }
    ctx.restore();
  }

  drawReel() {
    const c = this.reelCanvasRef.current;
    if (!c || this.state.mode !== 'reel') return;
    if (c.width !== 1080) { c.width = 1080; c.height = 1920; }
    const ctx = c.getContext('2d');
    const A = this._reelAssets || { frames: {} };
    const r = this.state.reel;
    const skins = this.reelSkins();
    const skin = skins.find(k => k.id === r.skin) || skins[0];
    const el = r.elements || {};
    ctx.clearRect(0, 0, 1080, 1920);
    const vdurC = this.state.reelDur || 0;
    const ctaC = r.cta || {};
    let tNow;
    const vEl = this._video;
    if (this._phase === 'cta') tNow = vdurC + (this._ctaT || 0);
    else if (vEl && (this.state.reelPlaying || this._recording)) tNow = vEl.currentTime;
    else tNow = this.state.reelT / 1000;
    if (ctaC.on && vdurC > 0 && tNow > vdurC + 0.001) {
      this.drawCtaCard(ctx, tNow - vdurC, el, this._reelAssets || {});
      return;
    }
    if (skin.img) {
      const im = A.frames[skin.img];
      if (im) this.coverDraw(ctx, im, im.width, im.height, { x: 0, y: 0, w: 1080, h: 1920 }, 1);
      else { ctx.fillStyle = skin.light ? '#F2EFE8' : '#141414'; ctx.fillRect(0, 0, 1080, 1920); }
    } else if (skin.under) skin.under(ctx);
    if (skin.accent && el.accent) skin.accent(ctx);
    const vr = skin.video;
    ctx.save();
    this.rrPath(ctx, vr.x, vr.y, vr.w, vr.h, vr.r || 0);
    ctx.clip();
    ctx.fillStyle = '#0B0B0B';
    ctx.fillRect(vr.x, vr.y, vr.w, vr.h);
    const v = this._video;
    if (v && v.readyState >= 2 && v.videoWidth) {
      this.coverDraw(ctx, v, v.videoWidth, v.videoHeight, vr, r.zoom);
    } else {
      ctx.fillStyle = '#54534F';
      ctx.font = '700 34px "JetBrains Mono", monospace';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText('DROP YOUR VIDEO', vr.x + vr.w / 2, vr.y + vr.h / 2);
    }
    ctx.restore();
    if (skin.over) skin.over(ctx);
    if (el.accent && skin.frameStroke) {
      ctx.strokeStyle = skin.frameStroke;
      ctx.lineWidth = 6;
      this.rrPath(ctx, vr.x + 3, vr.y + 3, vr.w - 6, vr.h - 6, Math.max(0, (vr.r || 0) - 3));
      ctx.stroke();
    }
    if (el.logo) {
      const lc = r.logoColor;
      const logo = lc === 'ink' ? A.ink : lc === 'white' ? A.white : (skin.light ? A.ink : A.white);
      if (logo && logo.height) {
        const lp = skin.logoPos || { x: 88, y: 90, h: 60 };
        const w = logo.width * (lp.h / logo.height);
        ctx.drawImage(logo, lp.center ? 540 - w / 2 : lp.x, lp.y, w, lp.h);
      }
    }
    if (el.footer) {
      const fy = skin.footerY || 1812;
      ctx.font = '700 26px "JetBrains Mono", monospace';
      try { ctx.letterSpacing = '5px'; } catch (e) {}
      ctx.textBaseline = 'middle';
      ctx.fillStyle = skin.light ? '#141414' : '#FFFFFF';
      if (skin.footerCenter) {
        ctx.textAlign = 'center';
        ctx.fillText('3DFILMPARTS.COM', 540, fy);
      } else {
        ctx.textAlign = 'left';
        ctx.fillText('3DFILMPARTS.COM', 88, fy);
        ctx.textAlign = 'right';
        ctx.fillStyle = '#E8231F';
        ctx.fillText('@3DFILMPARTS', 992, fy);
      }
      try { ctx.letterSpacing = '0px'; } catch (e) {}
    }
    if (el.progress && vdurC > 0) {
      // Sits above Instagram's bottom caption/CTA zone (~320px) so it never collides with reel UI text
      const p = Math.max(0, Math.min(1, tNow / vdurC));
      const px = 70, pw = 940, py = 1566, ph = 24;
      ctx.save();
      ctx.fillStyle = 'rgba(20,20,20,0.62)';
      this.rrPath(ctx, px, py, pw, ph, 12);
      ctx.fill();
      ctx.strokeStyle = 'rgba(242,239,232,0.5)';
      ctx.lineWidth = 2;
      this.rrPath(ctx, px, py, pw, ph, 12);
      ctx.stroke();
      if (p > 0.002) {
        ctx.save();
        this.rrPath(ctx, px + 3, py + 3, pw - 6, ph - 6, 9);
        ctx.clip();
        ctx.fillStyle = '#E8231F';
        ctx.fillRect(px + 3, py + 3, (pw - 6) * p, ph - 6);
        ctx.restore();
      }
      if (p > 0.01 && p < 0.99) {
        ctx.fillStyle = '#FFFFFF';
        ctx.fillRect(px + 3 + (pw - 6) * p - 3, py - 4, 6, ph + 8);
      }
      ctx.restore();
    }
    const bconf = r.badge || {};
    const bim = ((this._reelAssets || {}).badges || {})[bconf.id];
    if (bconf.id && bconf.id !== 'none' && bim && bim.width) {
      const animating = this.state.reelPlaying || this._recording;
      const pop = animating ? 1 - Math.pow(1 - Math.min(1, tNow / 0.45), 3) : 1;
      const bob = Math.sin(tNow * 2.2) * 10;
      const rot = Math.sin(tNow * 1.7) * 0.06;
      const size = 270 * Math.max(0.01, pop);
      const bx = bconf.pos === 'left' ? 195 : bconf.pos === 'center' ? 540 : 885;
      ctx.save();
      ctx.translate(bx, 235 + bob);
      ctx.rotate(rot);
      ctx.globalAlpha = Math.max(0, Math.min(1, pop));
      ctx.drawImage(bim, -size / 2, -size / 2, size, size);
      ctx.restore();
    }
    (r.overlays || []).forEach(o => this.drawReelOverlay(ctx, o, tNow));
  }

  drawReelOverlay(ctx, o, t) {
    const t0 = Number(o.start) || 0, dur = Number(o.dur) || 2;
    if (t < t0 || t > t0 + dur) return;
    const easeOut = (p) => 1 - Math.pow(1 - Math.min(1, Math.max(0, p)), 3);
    const ein = easeOut((t - t0) / 0.5);
    const eout = Math.min(1, Math.max(0, (t0 + dur - t) / 0.35));
    let dx = 0, dy = 0, sc = 1, alpha = ein * eout;
    if (o.effect === 'rise') dy = (1 - ein) * 70;
    if (o.effect === 'slide') dx = (1 - ein) * -90;
    if (o.effect === 'scale') sc = 0.85 + 0.15 * ein;
    if (o.effect === 'none') alpha = eout;
    const size = Number(o.size) || 90;
    const y = 1920 * ((Number(o.y) || 60) / 100);
    const text = String(o.text || '').toUpperCase();
    ctx.save();
    ctx.globalAlpha = Math.max(0, Math.min(1, alpha));
    ctx.translate(540 + dx, y + dy);
    ctx.scale(sc, sc);
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    if (o.kind === 'eyebrow') {
      ctx.font = '700 ' + Math.round(size * 0.42) + 'px "JetBrains Mono", monospace';
      try { ctx.letterSpacing = Math.round(size * 0.075) + 'px'; } catch (e) {}
      ctx.fillStyle = '#E8231F';
      ctx.fillText(text, 0, 0);
    } else if (o.kind === 'badge') {
      ctx.font = '700 ' + Math.round(size * 0.42) + 'px "JetBrains Mono", monospace';
      try { ctx.letterSpacing = Math.round(size * 0.05) + 'px'; } catch (e) {}
      const w = ctx.measureText(text).width;
      const ph = Math.round(size * 0.95), pw = w + size * 0.9;
      ctx.fillStyle = '#E8231F';
      ctx.fillRect(-pw / 2, -ph / 2, pw, ph);
      ctx.fillStyle = '#FFFFFF';
      ctx.fillText(text, 0, 0);
    } else {
      ctx.font = '900 ' + size + 'px Archivo, "Arial Black", sans-serif';
      try { ctx.letterSpacing = (-0.03 * size).toFixed(1) + 'px'; } catch (e) {}
      if (o.kind === 'headline-white') {
        ctx.shadowColor = 'rgba(0,0,0,.45)';
        ctx.shadowBlur = 28;
      }
      ctx.fillStyle = o.kind === 'headline-ink' ? '#141414' : '#FFFFFF';
      const words = text.split(/\s+/);
      const lines = [];
      let line = '';
      for (const wd of words) {
        const trial = line ? line + ' ' + wd : wd;
        if (ctx.measureText(trial).width > 904 && line) { lines.push(line); line = wd; }
        else line = trial;
      }
      if (line) lines.push(line);
      const lh = size * 0.98;
      const y0 = -((lines.length - 1) / 2) * lh;
      lines.forEach((ln, i) => ctx.fillText(ln, 0, y0 + i * lh));
    }
    ctx.restore();
  }

  readCtaImg(file) {
    if (!file || !file.type || file.type.indexOf('image') !== 0) return;
    const reader = new FileReader();
    reader.onload = () => this.setCta({ image: reader.result });
    reader.readAsDataURL(file);
  }

  toggleReelPlay() {
    const v = this._video;
    if (!v) { this.setState({ reelStatus: 'Add a video first' }); return; }
    if (this.state.reelPlaying) {
      v.pause();
      this.stopReel();
    } else {
      const vdur = this.state.reelDur || 0;
      const cta = this.state.reel.cta || {};
      const tSec = this.state.reelT / 1000;
      if (cta.on && vdur > 0 && tSec > vdur + 0.05) {
        this._phase = 'cta';
        this._ctaT = tSec - vdur;
        this._ctaStart = performance.now() - this._ctaT * 1000;
        this.setState({ reelPlaying: true, reelStatus: '' }, () => this.startReelLoop());
        return;
      }
      this._phase = 'video';
      if (v.ended || (vdur && tSec >= vdur - 0.05)) { try { v.currentTime = 0; } catch (e) {} }
      this.setState({ reelPlaying: true, reelStatus: '' }, () => {
        v.play().then(() => this.startReelLoop()).catch(() => {
          v.muted = true;
          v.play().then(() => this.startReelLoop()).catch(() => this.setState({ reelPlaying: false, reelStatus: 'Could not start playback' }));
        });
      });
    }
  }

  startReelLoop() {
    if (this._reelRaf) cancelAnimationFrame(this._reelRaf);
    const step = () => {
      if (!this.state.reelPlaying || this.state.mode !== 'reel') return;
      const vdur = this.state.reelDur || 0;
      if (this._phase === 'cta') {
        const cta = this.state.reel.cta || {};
        this._ctaT = (performance.now() - this._ctaStart) / 1000;
        if (this._ctaT >= (Number(cta.dur) || 3)) {
          this._phase = 'video';
          this.setState({ reelPlaying: false, reelT: 0 }, () => this.drawReel());
          return;
        }
        this.drawReel();
        if ((performance.now() - (this._reelTick || 0)) > 200) {
          this._reelTick = performance.now();
          this.setState({ reelT: Math.round((vdur + this._ctaT) * 1000) });
        }
        this._reelRaf = requestAnimationFrame(step);
        return;
      }
      this.drawReel();
      const v = this._video;
      if (v && (performance.now() - (this._reelTick || 0)) > 200) {
        this._reelTick = performance.now();
        this.setState({ reelT: Math.round(v.currentTime * 1000) });
      }
      this._reelRaf = requestAnimationFrame(step);
    };
    this._reelRaf = requestAnimationFrame(step);
  }

  stopReel() {
    if (this._reelRaf) cancelAnimationFrame(this._reelRaf);
    if (this._video) this._video.pause();
    if (this.state.reelPlaying) this.setState({ reelPlaying: false });
  }

  async exportReel() {
    const v = this._video, c = this.reelCanvasRef.current;
    if (!v) { this.setState({ reelStatus: 'Add a video first' }); return; }
    if (!c || this._recording) return;
    if (!window.MediaRecorder) { this.setState({ reelStatus: 'This browser cannot record video' }); return; }
    const mimes = ['video/mp4;codecs=avc1.640028', 'video/mp4;codecs=avc1.42E01E', 'video/mp4', 'video/webm;codecs=vp9', 'video/webm'];
    const mime = mimes.find(m => MediaRecorder.isTypeSupported(m));
    if (!mime) { this.setState({ reelStatus: 'No supported video format' }); return; }
    this._recording = true;
    this.stopReel();
    const ext = mime.indexOf('mp4') >= 0 ? 'mp4' : 'webm';
    this.setState({ reelStatus: 'Recording ' + ext.toUpperCase() + ' at ' + (this._fps || 30) + ' fps in real time (' + Math.round(this.state.reelDur) + 's)... keep this tab visible.' });
    try {
      await new Promise((res) => {
        const done = () => { v.removeEventListener('seeked', done); res(); };
        v.addEventListener('seeked', done);
        try { v.currentTime = 0; } catch (e) { v.removeEventListener('seeked', done); res(); }
      });
      this.drawReel();
      const stream = c.captureStream(this._fps || 30);
      try {
        const vs = v.captureStream ? v.captureStream() : (v.mozCaptureStream ? v.mozCaptureStream() : null);
        if (vs) vs.getAudioTracks().forEach(tr => stream.addTrack(tr));
      } catch (e) { /* no audio track available */ }
      const rec = new MediaRecorder(stream, { mimeType: mime, videoBitsPerSecond: 24000000, audioBitsPerSecond: 192000 });
      const chunks = [];
      rec.ondataavailable = (e) => { if (e.data && e.data.size) chunks.push(e.data); };
      const stopped = new Promise((res) => { rec.onstop = res; });
      rec.start(250);
      this._phase = 'video';
      await v.play();
      await new Promise((res) => {
        const step = () => {
          this.drawReel();
          if (v.ended) res();
          else requestAnimationFrame(step);
        };
        step();
      });
      const cta = this.state.reel.cta || {};
      if (cta.on) {
        this._phase = 'cta';
        this._ctaT = 0;
        this._ctaStart = performance.now();
        const cdur = Number(cta.dur) || 3;
        await new Promise((res) => {
          const step = () => {
            this._ctaT = (performance.now() - this._ctaStart) / 1000;
            this.drawReel();
            if (this._ctaT >= cdur) res();
            else requestAnimationFrame(step);
          };
          step();
        });
        this._phase = 'video';
      }
      rec.stop();
      await stopped;
      const blob = new Blob(chunks, { type: mime.split(';')[0] });
      const url = URL.createObjectURL(blob);
      const base = this.slug((this.state.videoName || 'reel').replace(/\.[a-z0-9]+$/i, ''));
      this.download(url, base + '_' + this.state.reel.skin + '_story_reel.' + ext);
      setTimeout(() => URL.revokeObjectURL(url), 5000);
      this.setState({ reelStatus: ext === 'webm' ? 'Saved as WebM (this browser cannot encode MP4)' : '', reelPlaying: false, reelT: 0 });
    } catch (e) {
      this.setState({ reelStatus: 'Export failed: ' + e });
    }
    this._recording = false;
  }

