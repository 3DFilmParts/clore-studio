  persist() {
    try {
      const slim = {};
      for (const k of Object.keys(this.state.settings)) {
        slim[k] = Object.assign({}, this.state.settings[k]);
        if (slim[k].custom1 && slim[k].custom1.length > 400000) slim[k] = Object.assign({}, slim[k], { custom1: null });
        if (slim[k].custom2 && slim[k].custom2.length > 400000) slim[k] = Object.assign({}, slim[k], { custom2: null });
      }
      const slimQueue = this.state.queue.map(q => {
        const c = Object.assign({}, q, { settings: Object.assign({}, q.settings) });
        if (c.settings.custom1 && c.settings.custom1.length > 400000) c.settings.custom1 = null;
        if (c.settings.custom2 && c.settings.custom2.length > 400000) c.settings.custom2 = null;
        return c;
      });
      localStorage.setItem('clore-studio-editor-v1', JSON.stringify({ active: this.state.active, settings: slim, queue: slimQueue, anim: this.state.anim, presets: this.state.presets,
        reel: (() => {
          const rr = JSON.parse(JSON.stringify(this.state.reel));
          if (rr.cta && rr.cta.image && rr.cta.image.length > 400000) rr.cta.image = null;
          return rr;
        })() }));
    } catch (e) { /* quota, keep in memory */ }
  }

  async componentDidMount() {
    try {
      const saved = localStorage.getItem('clore-studio-editor-v1');
      if (saved) {
        const s = JSON.parse(saved);
        if (s && s.settings) this.setState({
          settings: s.settings, active: s.active || this.state.active,
          queue: Array.isArray(s.queue) ? s.queue : [],
          anim: s.anim ? Object.assign({}, this.state.anim, s.anim) : this.state.anim,
          presets: Array.isArray(s.presets) ? s.presets : [],
          reel: s.reel ? Object.assign({}, this.state.reel, s.reel, {
            elements: Object.assign({}, this.state.reel.elements, s.reel.elements || {}),
            cta: Object.assign({}, this.state.reel.cta, s.reel.cta || {}),
            badge: Object.assign({}, this.state.reel.badge, s.reel.badge || {})
          }) : this.state.reel
        });
      }
    } catch (e) { /* ignore */ }
    try {
      const base = 'clore-templates/';
      const names = this.FILES.map(f => f.file);
      const [tokens, ...texts] = await Promise.all(
        [base + 'tokens.css', ...names.map(f => base + f)].map(u => fetch(u).then(r => {
          if (!r.ok) throw new Error('Failed to load ' + u);
          return r.text();
        }).catch(e => {
          const a = window.CLORE_ASSETS && window.CLORE_ASSETS[u];
          if (typeof a === 'string') return a;
          throw e;
        }))
      );
      const raw = {};
      names.forEach((f, i) => { raw[f] = texts[i]; });
      this.setState({ raw, tokens });
    } catch (e) {
      this.setState({ error: String(e) });
    }
    this.loadCatalog();
    this.loadImagesFor(this.cur().product);
    this.loadPresetFile();
  }

