      this.loadImg(this.assetUrl('clore-templates/reel-frames/badge-' + k + '.png')).then(im => { A.badges[k] = im; this.drawReel(); });
    });
    this.loadImg(this.assetUrl('clore-templates/preview-assets/logo-ink-transparent.png')).then(im => { A.ink = im; this.drawReel(); });
    this.loadImg(this.assetUrl('clore-templates/preview-assets/logo-white-transparent.png')).then(im => { A.white = im; this.drawReel(); });
    ['frame-a', 'frame-b', 'frame-c', 'frame-d', 'frame-e', 'frame-f', 'frame-g', 'frame-h', 'frame-i'].forEach(k => {
