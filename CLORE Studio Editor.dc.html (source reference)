<div style="display: flex; height: 100vh; overflow: hidden; font-family: 'JetBrains Mono', monospace; color: #141414">

  <div style="flex: 0 0 372px; overflow-y: auto; background: #FFFFFF; border-right: 2px solid #D3CFC3; padding: 28px 26px 60px; display: flex; flex-direction: column; gap: 26px">

    <div style="display: flex; flex-direction: column; gap: 6px">
      <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.18em; color: #E8231F; text-transform: lowercase">clore studio</div>
      <div style="font-family: 'Archivo', 'Arial Black', sans-serif; font-weight: 900; font-size: 24px; letter-spacing: -0.035em; line-height: 0.92; text-transform: uppercase">TEMPLATE EDITOR</div>
    </div>

    <div style="display: flex; gap: 6px">
      <button onClick="{{ onModeDesign }}" style="{{ modeDesignStyle }}">Design</button>
      <button onClick="{{ onModeAnim }}" style="{{ modeAnimStyle }}">Animation</button>
      <button onClick="{{ onModeBatch }}" style="{{ modeBatchStyle }}">Batch</button>
      <button onClick="{{ onModeReel }}" style="{{ modeReelStyle }}">Reel</button>
    </div>

    <div style="display: flex; flex-direction: column; gap: 8px">
      <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #54534F">Presets</div>
      <div style="display: flex; gap: 6px">
        <input placeholder="Preset name" value="{{ presetName }}" onChange="{{ onPresetName }}" style="font-family: 'JetBrains Mono', monospace; font-size: 12px; padding: 9px; border: 2px solid #D3CFC3; color: #141414; flex: 1 1 auto; min-width: 0; box-sizing: border-box">
        <button onClick="{{ onSavePreset }}" style="{{ queueBtnStyle }}">Save</button>
      </div>
      <sc-for list="{{ presetRows }}" as="p" hint-placeholder-count="2">
        <div style="display: flex; gap: 6px; align-items: stretch">
          <button onClick="{{ p.onApply }}" style="{{ p.applyStyle }}">{{ p.name }}</button>
          <button onClick="{{ p.onRemove }}" title="Delete preset" style="font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 11px; padding: 0 10px; border: 2px solid #D3CFC3; background: #fff; color: #54534F; cursor: pointer; flex: 0 0 auto">✕</button>
        </div>
      </sc-for>
      <div style="display: flex; gap: 6px; align-items: center; flex-wrap: wrap">
        <button onClick="{{ onExportPresets }}" style="{{ clearBtnStyle }}">Export file</button>
        <label style="font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; padding: 9px 14px; border: 2px solid #D3CFC3; background: #fff; color: #54534F; cursor: pointer">Import
          <input type="file" accept="application/json,.json" onChange="{{ onImportPresets }}" style="display: none">
        </label>
      </div>
      <div style="font-size: 10px; color: #8A8A86; line-height: 1.5">A preset stores template, format, toggles, crops, headline scale and all animation settings. Pick a product, apply a preset, then export or queue as usual. Presets live in this browser; Export file downloads presets.json, drop it into the project at clore-templates/presets.json (or import it here) and those presets load permanently on every device.</div>
    </div>

    <sc-if value="{{ isNotReel }}" hint-placeholder-val="{{ true }}">
    <div style="display: flex; flex-direction: column; gap: 8px">
      <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #54534F">Template</div>
      <div style="display: flex; flex-direction: column; gap: 6px">
        <sc-for list="{{ templates }}" as="t" hint-placeholder-count="6">
          <button onClick="{{ t.onSelect }}" style="{{ t.style }}">{{ t.name }}</button>
        </sc-for>
      </div>
    </div>

    <div style="display: flex; flex-direction: column; gap: 8px">
      <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #54534F">Format</div>
      <div style="display: flex; flex-wrap: wrap; gap: 6px">
        <sc-for list="{{ formats }}" as="f" hint-placeholder-count="5">
          <button onClick="{{ f.onSelect }}" style="{{ f.style }}">{{ f.short }}</button>
        </sc-for>
      </div>
    </div>

    <div style="display: flex; flex-direction: column; gap: 10px">
      <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #54534F">Product</div>
      <input placeholder="Search products" value="{{ productQuery }}" onChange="{{ onProductQuery }}" style="font-family: 'JetBrains Mono', monospace; font-size: 12px; padding: 10px; border: 2px solid #141414; color: #141414; width: 100%; box-sizing: border-box">
      <div style="display: flex; flex-direction: column; gap: 4px; max-height: 224px; overflow-y: auto; border: 2px solid #D3CFC3; padding: 6px; background: #fff">
        <sc-for list="{{ productResults }}" as="p" hint-placeholder-count="6">
          <button onClick="{{ p.onSelect }}" style="{{ p.style }}">{{ p.label }}</button>
        </sc-for>
      </div>
      <div style="font-size: 10px; color: #8A8A86; line-height: 1.5">{{ productCount }} Picking a product fills title, price, eyebrow, badge and images. Edit anything after.</div>
    </div>

    <div style="display: flex; flex-direction: column; gap: 10px">
      <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #54534F">Copy</div>
      <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Title
        <input value="{{ title }}" onChange="{{ onTitle }}" style="font-family: 'JetBrains Mono', monospace; font-size: 12px; padding: 10px; border: 2px solid #D3CFC3; color: #141414; width: 100%; box-sizing: border-box">
      </label>
      <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Headline scale {{ titleScaleLabel }}
        <input type="range" min="0.5" max="1.6" step="0.05" value="{{ titleScale }}" onChange="{{ onTitleScale }}" style="width: 100%">
      </label>
      <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Eyebrow
        <input value="{{ eyebrow }}" onChange="{{ onEyebrow }}" style="font-family: 'JetBrains Mono', monospace; font-size: 12px; padding: 10px; border: 2px solid #D3CFC3; color: #141414; width: 100%; box-sizing: border-box">
      </label>
      <div style="display: flex; gap: 8px; align-items: flex-end">
        <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86; flex: 1">Price
          <input value="{{ price }}" onChange="{{ onPrice }}" style="font-family: 'JetBrains Mono', monospace; font-size: 12px; padding: 10px; border: 2px solid #D3CFC3; color: #141414; width: 100%; box-sizing: border-box">
        </label>
        <button onClick="{{ onTogglePrice }}" style="{{ priceToggleStyle }}">{{ priceToggleLabel }}</button>
      </div>
      <div style="display: flex; gap: 8px; align-items: flex-end">
        <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86; flex: 1">Badge
          <input value="{{ badge }}" onChange="{{ onBadge }}" style="font-family: 'JetBrains Mono', monospace; font-size: 12px; padding: 10px; border: 2px solid #D3CFC3; color: #141414; width: 100%; box-sizing: border-box">
        </label>
        <button onClick="{{ onToggleBadge }}" style="{{ badgeToggleStyle }}">{{ badgeToggleLabel }}</button>
      </div>
    </div>

    <div style="display: flex; flex-direction: column; gap: 8px">
      <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #54534F">Logo colour</div>
      <div style="display: flex; gap: 6px">
        <sc-for list="{{ logoColorOpts }}" as="o" hint-placeholder-count="3">
          <button onClick="{{ o.onPick }}" style="{{ o.style }}">{{ o.label }}</button>
        </sc-for>
      </div>
    </div>

    <sc-if value="{{ isTapeTpl }}" hint-placeholder-val="{{ false }}">
      <div style="display: flex; flex-direction: column; gap: 8px">
        <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #54534F">Tape ground</div>
        <div style="display: flex; flex-direction: column; gap: 6px">
          <sc-for list="{{ tapeBgOpts }}" as="o" hint-placeholder-count="5">
            <button onClick="{{ o.onPick }}" style="{{ o.style }}">{{ o.label }}</button>
          </sc-for>
        </div>
        <div style="font-size: 10px; color: #8A8A86; line-height: 1.5">All five Camera Tape grounds work in Design and Animation. Dark and red grounds switch to the white logo automatically.</div>
      </div>
    </sc-if>
    </sc-if>

    <sc-if value="{{ isDesign }}" hint-placeholder-val="{{ true }}">
    <sc-if value="{{ hasImage1 }}" hint-placeholder-val="{{ true }}">
      <div style="display: flex; flex-direction: column; gap: 10px">
        <div style="display: flex; align-items: center; justify-content: space-between">
          <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #54534F">Hero image</div>
          <div style="display: flex; gap: 6px">
            <button onClick="{{ onPrev1 }}" style="font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 13px; width: 30px; height: 30px; border: 2px solid #141414; background: #fff; color: #141414; cursor: pointer">&lt;</button>
            <button onClick="{{ onNext1 }}" style="font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 13px; width: 30px; height: 30px; border: 2px solid #141414; background: #fff; color: #141414; cursor: pointer">&gt;</button>
          </div>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 6px">
          <sc-for list="{{ thumbs1 }}" as="th" hint-placeholder-count="8">
            <div onClick="{{ th.onPick }}" style="{{ th.style }}"></div>
          </sc-for>
        </div>
        <div onDrop="{{ onDrop1 }}" onDragOver="{{ onDragOver }}" style="border: 2px dashed #D3CFC3; padding: 14px; text-align: center; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86; display: flex; flex-direction: column; gap: 8px; align-items: center">
          <span>Drop your own image here</span>
          <input type="file" accept="image/*" onChange="{{ onFile1 }}" style="font-size: 10px; max-width: 100%">
          <sc-if value="{{ hasCustom1 }}" hint-placeholder-val="{{ false }}">
            <button onClick="{{ onClearCustom1 }}" style="font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 10px; letter-spacing: 0.1em; padding: 6px 12px; border: 2px solid #E8231F; background: #fff; color: #E8231F; cursor: pointer; text-transform: uppercase">Remove custom image</button>
          </sc-if>
        </div>
        <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Image scale {{ scale1Label }}
          <input type="range" min="0.5" max="3" step="0.05" value="{{ scale1 }}" onChange="{{ onScale1 }}" style="width: 100%">
        </label>
        <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Horizontal position {{ posX1Label }}
          <input type="range" min="0" max="100" step="1" value="{{ posX1 }}" onChange="{{ onPosX1 }}" style="width: 100%">
        </label>
        <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Vertical position {{ posY1Label }}
          <input type="range" min="0" max="100" step="1" value="{{ posY1 }}" onChange="{{ onPosY1 }}" style="width: 100%">
        </label>
      </div>
    </sc-if>

    <sc-if value="{{ hasImage2 }}" hint-placeholder-val="{{ false }}">
      <div style="display: flex; flex-direction: column; gap: 10px">
        <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #54534F">{{ image2Label }}</div>
        <div style="display: flex; flex-wrap: wrap; gap: 6px">
          <sc-for list="{{ thumbs2 }}" as="th" hint-placeholder-count="8">
            <div onClick="{{ th.onPick }}" style="{{ th.style }}"></div>
          </sc-for>
        </div>
        <div onDrop="{{ onDrop2 }}" onDragOver="{{ onDragOver }}" style="border: 2px dashed #D3CFC3; padding: 14px; text-align: center; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86; display: flex; flex-direction: column; gap: 8px; align-items: center">
          <span>Drop your own image here</span>
          <input type="file" accept="image/*" onChange="{{ onFile2 }}" style="font-size: 10px; max-width: 100%">
          <sc-if value="{{ hasCustom2 }}" hint-placeholder-val="{{ false }}">
            <button onClick="{{ onClearCustom2 }}" style="font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 10px; letter-spacing: 0.1em; padding: 6px 12px; border: 2px solid #E8231F; background: #fff; color: #E8231F; cursor: pointer; text-transform: uppercase">Remove custom image</button>
          </sc-if>
        </div>
        <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Image scale {{ scale2Label }}
          <input type="range" min="0.5" max="3" step="0.05" value="{{ scale2 }}" onChange="{{ onScale2 }}" style="width: 100%">
        </label>
        <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Horizontal position {{ posX2Label }}
          <input type="range" min="0" max="100" step="1" value="{{ posX2 }}" onChange="{{ onPosX2 }}" style="width: 100%">
        </label>
        <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Vertical position {{ posY2Label }}
          <input type="range" min="0" max="100" step="1" value="{{ posY2 }}" onChange="{{ onPosY2 }}" style="width: 100%">
        </label>
      </div>
    </sc-if>
    </sc-if>

    <sc-if value="{{ isAnim }}" hint-placeholder-val="{{ false }}">
      <div style="display: flex; flex-direction: column; gap: 10px">
        <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #54534F">Layers</div>
        <sc-if value="{{ noLayers }}" hint-placeholder-val="{{ false }}">
          <div style="font-size: 10px; color: #8A8A86; line-height: 1.5">Layer list appears once the stage has built.</div>
        </sc-if>
        <sc-for list="{{ layerRows }}" as="l" hint-placeholder-count="4">
          <div style="display: flex; flex-direction: column; gap: 6px; border-bottom: 1px solid #EDEBE5; padding-bottom: 8px">
            <div style="display: flex; gap: 8px; align-items: center; justify-content: space-between">
              <span style="font-size: 11px; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: #141414">{{ l.name }}</span>
              <button onClick="{{ l.onToggle }}" style="{{ l.toggleStyle }}">{{ l.toggleLabel }}</button>
            </div>
            <div style="display: flex; gap: 8px; align-items: center">
              <select value="{{ l.effect }}" onChange="{{ l.onEffect }}" style="font-family: 'JetBrains Mono', monospace; font-size: 10px; padding: 5px; border: 2px solid #D3CFC3; background: #fff; color: #141414; flex: 0 0 auto">
                <option value="global">Global effect</option>
                <option value="fade">Fade</option>
                <option value="rise">Rise</option>
                <option value="slide">Slide</option>
                <option value="scale">Scale</option>
                <option value="none">None</option>
              </select>
              <input type="range" min="0" max="2" step="0.05" value="{{ l.delay }}" onChange="{{ l.onDelay }}" style="flex: 1 1 auto; min-width: 40px">
              <span style="font-size: 10px; color: #8A8A86; flex: 0 0 auto">{{ l.delayLabel }}</span>
            </div>
          </div>
        </sc-for>
        <div style="font-size: 10px; color: #8A8A86; line-height: 1.5">Each layer can be hidden, given its own entrance effect, and an extra delay on top of the global stagger.</div>
      </div>

      <div style="display: flex; flex-direction: column; gap: 10px">
        <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #54534F">Text animation</div>
        <div style="display: flex; flex-wrap: wrap; gap: 6px">
          <sc-for list="{{ textEffectOpts }}" as="o" hint-placeholder-count="4">
            <button onClick="{{ o.onPick }}" style="{{ o.style }}">{{ o.label }}</button>
          </sc-for>
        </div>
        <div style="font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Easing</div>
        <div style="display: flex; flex-wrap: wrap; gap: 6px">
          <sc-for list="{{ easingOpts }}" as="o" hint-placeholder-count="4">
            <button onClick="{{ o.onPick }}" style="{{ o.style }}">{{ o.label }}</button>
          </sc-for>
        </div>
        <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Duration {{ textDurLabel }}
          <input type="range" min="0.2" max="2.5" step="0.05" value="{{ textDur }}" onChange="{{ onTextDur }}" style="width: 100%">
        </label>
        <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Stagger {{ textStaggerLabel }}
          <input type="range" min="0" max="1" step="0.02" value="{{ textStagger }}" onChange="{{ onTextStagger }}" style="width: 100%">
        </label>
        <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Start delay {{ textDelayLabel }}
          <input type="range" min="0" max="2" step="0.05" value="{{ textDelay }}" onChange="{{ onTextDelay }}" style="width: 100%">
        </label>
      </div>

      <sc-if value="{{ animHasImages }}" hint-placeholder-val="{{ true }}">
        <div style="display: flex; flex-direction: column; gap: 10px">
          <div style="font-weight: 700; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #54534F">Image animation</div>
          <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Images in cycle {{ imageCountLabel }}
            <input type="range" min="1" max="5" step="1" value="{{ imageCount }}" onChange="{{ onImageCount }}" style="width: 100%">
          </label>
          <div style="font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Entrance</div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px">
            <sc-for list="{{ imageEntranceOpts }}" as="o" hint-placeholder-count="4">
              <button onClick="{{ o.onPick }}" style="{{ o.style }}">{{ o.label }}</button>
            </sc-for>
          </div>
          <label style="display: flex; flex-direction: column; gap: 4px; font-size: 10px; letter-spacing: 0.07em; text-transform: uppercase; color: #8A8A86">Hold per image {{ holdLabel }}
