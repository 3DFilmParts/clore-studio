  rrPath(ctx, x, y, w, h, r) {
    r = Math.max(0, Math.min(r || 0, w / 2, h / 2));
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.arcTo(x + w, y, x + w, y + h, r);
    ctx.arcTo(x + w, y + h, x, y + h, r);
    ctx.arcTo(x, y + h, x, y, r);
    ctx.arcTo(x, y, x + w, y, r);
    ctx.closePath();
  }

  reelStripes(ctx, y, h) {
    ctx.save();
    ctx.beginPath(); ctx.rect(0, y, 1080, h); ctx.clip();
    ctx.fillStyle = '#F2EFE8'; ctx.fillRect(0, y, 1080, h);
    ctx.fillStyle = '#141414';
    for (let x = -h * 2; x < 1080 + h; x += 84) {
      ctx.beginPath();
      ctx.moveTo(x, y + h); ctx.lineTo(x + h, y); ctx.lineTo(x + h + 42, y); ctx.lineTo(x + 42, y + h);
      ctx.closePath(); ctx.fill();
    }
    ctx.restore();
  }

  coverDraw(ctx, media, mw, mh, rect, zoom) {
    if (!mw || !mh) return;
    const sc = Math.max(rect.w / mw, rect.h / mh) * (zoom || 1);
    const dw = mw * sc, dh = mh * sc;
    ctx.drawImage(media, rect.x + (rect.w - dw) / 2, rect.y + (rect.h - dh) / 2, dw, dh);
  }

  drawTimecode(ctx) {
    const v = this._video;
    const fps = this._fps || 30;
    const t = v && (this.state.reelPlaying || this._recording) ? v.currentTime : this.state.reelT / 1000;
    const pad = (n) => ('0' + Math.floor(n)).slice(-2);
    const str = pad(t / 3600) + ':' + pad((t / 60) % 60) + ':' + pad(t % 60) + ':' + pad((t % 1) * fps);
    const y = this.state.reel.tcPos === 'bottom' ? (this.state.reel.skin === 'noirtc' ? 1600 : 1630) : 170;
    ctx.save();
    const tcs = Number(this.state.reel.tcScale) || 1;
    ctx.translate(540, y + 75);
    ctx.scale(tcs, tcs);
    ctx.translate(-540, -(y + 75));
    ctx.fillStyle = 'rgba(8,8,8,0.85)';
    this.rrPath(ctx, 70, y, 940, 150, 14);
    ctx.fill();
    ctx.strokeStyle = '#2A2A2A';
    ctx.lineWidth = 3;
    this.rrPath(ctx, 70, y, 940, 150, 14);
    ctx.stroke();
    ctx.textBaseline = 'middle';
    ctx.font = '700 22px "JetBrains Mono", monospace';
    try { ctx.letterSpacing = '4px'; } catch (e) {}
    ctx.fillStyle = '#8A8A86';
    ctx.textAlign = 'left';
    ctx.fillText('TC', 100, y + 42);
    ctx.textAlign = 'right';
    ctx.fillText(fps + ' FPS', 980, y + 42);
    ctx.font = '700 86px "JetBrains Mono", monospace';
    try { ctx.letterSpacing = '10px'; } catch (e) {}
    ctx.textAlign = 'center';
    ctx.shadowColor = '#E8231F';
    ctx.shadowBlur = 26;
    ctx.fillStyle = '#FF4438';
    ctx.fillText(str, 540, y + 90);
    ctx.restore();
  }

