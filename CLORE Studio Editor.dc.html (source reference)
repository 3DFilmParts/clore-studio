  setVideo(file) {
    if (!file || !file.type || file.type.indexOf('video') !== 0) {
      if (file) this.setState({ reelStatus: 'That file is not a video' });
      return;
    }
    if (this._videoUrl) URL.revokeObjectURL(this._videoUrl);
    this._videoUrl = URL.createObjectURL(file);
    const v = this._video || document.createElement('video');
    this._video = v;
    v.playsInline = true;
    v.preload = 'auto';
    v.onloadedmetadata = () => this.setState({ reelDur: v.duration, videoName: file.name, reelT: 0, reelStatus: '' }, () => {
      if (v.requestVideoFrameCallback) this.measureFps(v);
      else { try { v.currentTime = 0.01; } catch (e) { this.drawReel(); } }
    });
    v.onseeked = () => this.drawReel();
    v.onended = () => {
      const cta = this.state.reel.cta || {};
      if (this.state.reelPlaying && cta.on) {
        this._phase = 'cta';
        this._ctaT = 0;
        this._ctaStart = performance.now();
      } else {
        if (this._reelRaf) cancelAnimationFrame(this._reelRaf);
        this.setState({ reelPlaying: false });
      }
    };
    v.src = this._videoUrl;
  }

  shuffleBatch() {
    const cat = (this.state.catalog || this.PRODUCTS.map((p, i) => this.productFromIdx(i))).slice();
    for (let i = cat.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      const t = cat[i]; cat[i] = cat[j]; cat[j] = t;
    }
    this.setState({ batch: cat.slice(0, 10) });
  }

  batchSettings(p) {
    return Object.assign({}, this.cur(), {
      product: p, title: p.title, eyebrow: p.eyebrow, price: p.price,
      badge: this.cur().badge,
      img1: p.images[0], img2: p.images[1] || p.images[0],
      custom1: null, custom2: null,
      scale1: 1, scale2: 1, posX1: 50, posY1: 50, posX2: 50, posY2: 50
    });
