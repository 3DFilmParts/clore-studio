<script type="text/x-dc" data-dc-script>
class Component extends DCLogic {
  state = { raw: null, tokens: '', error: null, active: 'T02-editorial.html', settings: {}, productImages: {}, catalog: null, productQuery: '', queue: [], exporting: '', hq: true,
    mode: 'design',
    anim: { textEffect: 'rise', easing: 'smooth', textDuration: 0.8, textStagger: 0.18, textDelay: 0.2, imageCount: 3, imageEntrance: 'scale', hold: 1.8, transition: 'fade', transDuration: 0.6, kenburns: true, kbAmount: 0.12, loop: true },
    animPlaying: false, animT: 0, animLayers: null, animStatus: '', presets: [], presetName: '',
    reel: { skin: 'signal', zoom: 1, tcPos: 'top', tcScale: 1, badge: { id: 'none', pos: 'right' }, elements: { logo: true, footer: true, accent: true, progress: true }, overlays: [],
      cta: { on: false, dur: 3, bg: 'red', headline: 'GET YOURS AT', sub: '3DFILMPARTS.COM', size: 104, textY: 28, image: null, frame: 'white', radius: 28, imgSize: 58, imgY: 62 } },
    reelPlaying: false, reelT: 0, reelDur: 0, reelStatus: '', videoName: '' };

  savePreset() {
    const s = this.cur();
    const name = (this.state.presetName || '').trim() || 'Preset ' + (this.state.presets.length + 1);
    const p = {
      id: Date.now() + '-' + Math.random().toString(36).slice(2, 6),
      name,
      file: this.state.active,
      format: s.format,
      design: {
        priceOn: s.priceOn, badgeOn: s.badgeOn, titleScale: s.titleScale ?? 1,
        scale1: s.scale1, scale2: s.scale2,
        posX1: s.posX1, posY1: s.posY1, posX2: s.posX2, posY2: s.posY2
      },
      anim: JSON.parse(JSON.stringify(this.state.anim))
